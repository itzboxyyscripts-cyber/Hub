--[[
    Auto Green - Basketball Legends
    Rayfield UI
]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local cloneref = cloneref or function(v) return v end
local player = Players.LocalPlayer
local Char = player.Character or player.CharacterAdded:Wait()

local visualGui = player.PlayerGui:WaitForChild("Visual")
local shootingElement = visualGui:WaitForChild("Shooting")
local Shoot = ReplicatedStorage.Packages.Knit.Services.ControlService.RE.Shoot

local autoShootEnabled = false
local shootPower = 0.8
local visibleConn = nil

local speedEnabled = false
local desiredSpeed = 16
local speedConnection = nil

local function startCFrameSpeed(speed)
    local connection
    connection = RunService.RenderStepped:Connect(function(deltaTime)
        local character = player.Character
        if not character then return end
        local root = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not root or not humanoid then return end

        local moveVec = humanoid.MoveDirection
        if moveVec.Magnitude > 0 then
            local speedDelta = math.max(speed - humanoid.WalkSpeed, 0)
            root.CFrame = root.CFrame + (moveVec.Unit * speedDelta * deltaTime)
        end
    end)
    return function()
        if connection then
            connection:Disconnect()
        end
    end
end

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "itzboxyy scripts",
    LoadingTitle = "itzboxyy scripts",
    LoadingSubtitle = "Basketball Legends",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "AutoGreen",
        FileName = "Config"
    },
    KeySystem = false,
})

local MainTab = Window:CreateTab("Auto Green", "target")

MainTab:CreateToggle({
    Name = "Auto Green",
    CurrentValue = false,
    Flag = "AutoGreen",
    Callback = function(value)
        autoShootEnabled = value
        if autoShootEnabled then
            if not visibleConn then
                visibleConn = shootingElement:GetPropertyChangedSignal("Visible"):Connect(function()
                    if autoShootEnabled and shootingElement.Visible == true then
                        task.wait(0.25)
                        Shoot:FireServer(shootPower)
                    end
                end)
            end
            Rayfield:Notify({
                Title = "Auto Green",
                Content = "Enabled",
                Duration = 3,
                Image = 4483362458,
            })
        else
            if visibleConn then
                visibleConn:Disconnect()
                visibleConn = nil
            end
        end
    end
})

MainTab:CreateSlider({
    Name = "Shot Timing",
    Range = {50, 100},
    Increment = 1,
    Suffix = "%",
    CurrentValue = 80,
    Flag = "ShotPower",
    Callback = function(value)
        shootPower = value / 100
    end
})

MainTab:CreateSection("Shot Timing Guide")
MainTab:CreateLabel("80% = Mediocre")
MainTab:CreateLabel("90% = Good")
MainTab:CreateLabel("95% = Great")
MainTab:CreateLabel("100% = Perfect")

MainTab:CreateSection("Speed")

MainTab:CreateToggle({
    Name = "Speed Boost",
    CurrentValue = false,
    Flag = "SpeedBoost",
    Callback = function(value)
        speedEnabled = value
        if value then
            if speedConnection then speedConnection() end
            speedConnection = startCFrameSpeed(desiredSpeed)
            Rayfield:Notify({
                Title = "Speed Boost",
                Content = "Enabled",
                Duration = 2,
                Image = 4483362458,
            })
        else
            if speedConnection then
                speedConnection()
                speedConnection = nil
            end
        end
    end
})

MainTab:CreateSlider({
    Name = "Speed Amount",
    Range = {16, 100},
    Increment = 1,
    Suffix = " speed",
    CurrentValue = 16,
    Flag = "SpeedAmount",
    Callback = function(value)
        desiredSpeed = value
        if speedEnabled then
            if speedConnection then speedConnection() end
            speedConnection = startCFrameSpeed(desiredSpeed)
        end
    end
})

local KeybindTab = Window:CreateTab("Keybinds", "keyboard")

KeybindTab:CreateKeybind({
    Name = "Toggle Auto Green",
    CurrentKeybind = "P",
    HoldToInteract = false,
    Flag = "ToggleKey",
    Callback = function()
        autoShootEnabled = not autoShootEnabled
        if autoShootEnabled then
            if not visibleConn then
                visibleConn = shootingElement:GetPropertyChangedSignal("Visible"):Connect(function()
                    if autoShootEnabled and shootingElement.Visible == true then
                        task.wait(0.25)
                        Shoot:FireServer(shootPower)
                    end
                end)
            end
        else
            if visibleConn then
                visibleConn:Disconnect()
                visibleConn = nil
            end
        end
        Rayfield:Notify({
            Title = "Auto Green",
            Content = autoShootEnabled and "Enabled" or "Disabled",
            Duration = 2,
            Image = 4483362458,
        })
    end
})

player.CharacterRemoving:Connect(function()
    if visibleConn then
        visibleConn:Disconnect()
        visibleConn = nil
    end
    if speedConnection then
        speedConnection()
        speedConnection = nil
    end
end)

Rayfield:LoadConfiguration() 
